{
  "name": "family-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "bin": {
    "famagent": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node --enable-source-maps dist/index.js",
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "cli": "node --enable-source-maps dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:orchestrator": "vitest run src/runtime/__tests__/orchestrator.spec.ts"
  },
  "dependencies": {
    "@lancedb/lancedb": "0.18.2",
    "playwright": "1.58.2",
    "telegram": "^2.26.16"
  },
  "devDependencies": {
    "@types/node": "24.12.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
