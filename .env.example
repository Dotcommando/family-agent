AGENT_NAME=family-agent
AGENT_PORT=3000
OLLAMA_BASE_URL=http://ollama:11434
LANCEDB_DIR=/app/data/lancedb
MEMORY_DIR=/app/memory
SECRETS_DIR=/run/secrets

# Event-driven loop settings
AGENT_EVENT_POLL_SECONDS=10
AGENT_IDLE_BACKOFF_SECONDS=30
AGENT_THOUGHT_LOOP_SECONDS=240
AGENT_MAX_CONCURRENT_JOBS=1
AGENT_PROACTIVE_MODE=true

# Queue and coalescing settings
AGENT_QUEUE_DIR=/app/state/queue
AGENT_COALESCE_WINDOW_SECONDS=45
AGENT_DEDUP_THOUGHT_LOOP=true
AGENT_DEDUP_SUMMARY_JOBS=true

# Memory summarization horizons
AGENT_SUMMARIZATION_MILESTONES=1h,3h,6h,24h,7d,30d,90d,180d,365d
AGENT_SUMMARIZATION_MAX_INPUT_ITEMS=200
AGENT_SUMMARY_RUN_ONLY_WHEN_IDLE=true
AGENT_SUMMARY_MIN_IDLE_SECONDS=60
AGENT_SUMMARY_MAX_CONCURRENT=1
AGENT_SUMMARY_RAW_RETENTION_DAYS=14

# Event stacking and batching
AGENT_MESSAGE_BATCH_WINDOW_SECONDS=30
AGENT_CHAT_COALESCE_MAX_ITEMS=20
AGENT_EVENT_QUEUE_STRATEGY=priority-fifo
AGENT_THOUGHT_LOOP_SKIP_WHEN_QUEUE_NOT_EMPTY=true
